{
  "configurations": [

    {
      "name": "Python Debugger: Current File",
      "type": "debugpy",
      "request": "launch",
      "program": "${file}",
      "cwd": "${fileDirname}",
      "console": "integratedTerminal",
      "justMyCode": true
    },
    {
      "name": "Python Debugger: Current Workspace",
      "type": "debugpy",
      "request": "launch",
      "program": "${file}",
      "cwd": "${fileDirname}/..",
      "console": "integratedTerminal",
      "justMyCode": true,
      "env": {
          "PYTHONPATH": "${workspaceFolder}"
      }
    },    

  ]
}